{
  "name": "aidoc-kit",
  "version": "0.1.3",
  "description": "AI-native documentation scanner for JS/TS projects",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aidoc-kit": "dist/cli.js"
  },
  "scripts": {
    "build": "node --eval \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js 2>/dev/null || echo 'No tests yet — build passed'",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "documentation",
    "codemod",
    "typescript",
    "ast",
    "agents",
    "copilot",
    "llm",
    "jsdoc",
    "knowledge-base"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clemsrec/aidoc-kit.git"
  },
  "homepage": "https://github.com/Clemsrec/aidoc-kit#readme",
  "bugs": {
    "url": "https://github.com/Clemsrec/aidoc-kit/issues"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
